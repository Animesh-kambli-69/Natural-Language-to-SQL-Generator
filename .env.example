# MongoDB
MONGO_URI=mongodb://localhost:27017/nl2sql

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=nl2sql_auth

# API ports
BACKEND_PORT=4000
FASTAPI_PORT=8000

# Python AI service URL used by Express
AI_SERVICE_URL=http://127.0.0.1:8000
AI_SERVICE_TOKEN=replace-with-shared-service-token

# Frontend URL used by CORS in backend
FRONTEND_ORIGIN=http://localhost:5173

# Optional frontend API base URL
VITE_API_BASE_URL=http://localhost:4000

# AI service behavior
LLM_MODE=mock
LLM_MAX_RESPONSE_MS=850
